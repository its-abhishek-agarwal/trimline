{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Trimline",
  "version": "0.1.10",
  "identifier": "com.abhic.trimline",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Trimline",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "decorations": true,
        "fullscreen": false,
        "minWidth": 900,
        "minHeight": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": [
      "resources/bin/ffmpeg.exe",
      "resources/bin/ffprobe.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "compression": "bzip2"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
